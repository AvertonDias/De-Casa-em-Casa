rules_version = '2';

service cloud.firestore {
    match /databases/{database}/documents {

        function isAuth() { return request.auth != null; }
        
        function getUserData(userId) { 
            let path = /databases/$(database)/documents/users/$(userId);
            return exists(path) ? get(path).data : null; 
        }
        
        function isUserInCongregation(congId) { 
            let userData = getUserData(request.auth.uid); 
            return userData != null && userData.congregationId == congId; 
        }
        
        function isAtivo() {
            let userData = getUserData(request.auth.uid);
            return userData != null && userData.status == 'ativo';
        }
        
        function isRole(role) { 
            let userData = getUserData(request.auth.uid); 
            return userData != null && userData.role == role; 
        }
        
        function isAdmin() { return isRole('Administrador'); }
        function isDirigente() { return isRole('Dirigente'); }
        function isServoTerritorios() { return isRole('Servo de Territórios'); }
        function isAjudante() { return isRole('Ajudante de Servo de Territórios'); }
        function canApproveUsers() { return isServoTerritorios() || isDirigente() || isAdmin() || isAjudante(); }

        match /congregations/{congId} {
            // Permitimos a leitura pública para que usuários possam encontrar sua congregação pelo número no cadastro
            allow read: if true; 
            
            // Somente usuários autenticados podem criar uma congregação
            allow create: if isAuth();
            
            // Permitir que membros ativos atualizem para que contadores globais funcionem
            allow update: if isUserInCongregation(congId) && (isAtivo() || canApproveUsers());
            
            // Somente o Administrador da própria congregação pode excluir
            allow delete: if isUserInCongregation(congId) && isAdmin();

            match /territories/{terrId} {
                // Só permite leitura se estiver na congregação E for ativo OU tiver cargo de gerência
                allow read: if isUserInCongregation(congId) && (isAtivo() || canApproveUsers());
                allow create, delete: if isUserInCongregation(congId) && (isAdmin() || isServoTerritorios());
                allow update: if isUserInCongregation(congId) && (isAtivo() || canApproveUsers());

                match /quadras/{quadraId} {
                    allow read, write: if isUserInCongregation(congId) && (isAtivo() || canApproveUsers());
                    match /casas/{casaId} { 
                        allow read, write: if isUserInCongregation(congId) && (isAtivo() || canApproveUsers()); 
                    }
                }
                match /activityHistory/{activityId} { 
                    allow read, write: if isUserInCongregation(congId) && (isAtivo() || canApproveUsers()); 
                }
            }
        }

        match /users/{userId} {
            allow create: if isAuth() && request.auth.uid == userId;
            allow get: if isAuth();
            allow list: if isAuth();
            allow update: if isAuth() && (request.auth.uid == userId || canApproveUsers());
            // Permite que Administradores excluam o documento de outros usuários
            allow delete: if isAuth() && isAdmin();

            // Regras para a subcoleção de notificações
            match /notifications/{notifId} {
                // O próprio usuário pode ler, atualizar (marcar como lido) e excluir suas notificações
                allow get, list, update, delete: if isAuth() && request.auth.uid == userId;
                
                // Administradores e servos podem criar notificações para outros usuários (usado nas designações)
                allow create: if isAuth() && (request.auth.uid == userId || canApproveUsers());
            }
        }

        match /feedbacks/{feedbackId} { allow create: if isAuth(); }
    }
}