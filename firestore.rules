rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- Funções de Ajuda ---
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function isMemberActive(congregationId) {
      let userData = getUserData();
      return request.auth != null &&
             userData.congregationId == congregationId &&
             userData.status == 'ativo';
    }

    function isAdmin(congregationId) {
      let userData = getUserData();
      return isMemberActive(congregationId) &&
             userData.role == 'Administrador';
    }

    function isAtLeastDirigente(congregationId) {
      let userData = getUserData();
      return isMemberActive(congregationId) &&
             (userData.role == 'Administrador' || userData.role == 'Dirigente');
    }

    // --- Regras para Coleções ---
    match /congregations/{congregationId} {
      allow get: if isMemberActive(congregationId);
      allow list: if request.auth != null; // Permite buscar congregações no cadastro/login
      allow create, update: if isAdmin(congregationId);
    }

    match /users/{userId} {
      allow create: if true; 
      allow get: if request.auth.uid == userId || isAtLeastDirigente(getUserData().congregationId);
      allow list: if isAtLeastDirigente(getUserData().congregationId);
      allow delete: if isAdmin(getUserData().congregationId);
      allow update: if 
          // 1. Um admin pode atualizar qualquer campo de qualquer usuário da sua congregação.
          isAdmin(getUserData().congregationId) ||
          // 2. Um dirigente pode atualizar o status de um usuário de 'pendente' ou 'rejeitado' para 'ativo'.
          (
            isAtLeastDirigente(getUserData().congregationId) && 
            (resource.data.status == 'pendente' || resource.data.status == 'rejeitado') && 
            request.resource.data.status == 'ativo'
          ) ||
          // 3. O próprio usuário pode atualizar apenas seus dados não-críticos.
          (
            request.auth.uid == userId &&
            // Garante que APENAS os campos listados estão sendo alterados. Nada mais.
            request.resource.data.keys().hasOnly(['name', 'email', 'congregationId', 'role', 'status', 'isOnline', 'lastSeen', 'fcmTokens']) &&
            // Garante que o usuário não pode mudar seus próprios dados críticos.
            request.resource.data.role == resource.data.role &&
            request.resource.data.status == resource.data.status &&
            request.resource.data.congregationId == resource.data.congregationId
          );
    }
    
    match /congregations/{congregationId}/territories/{territoryId} {
      allow read, create, delete, update: if isMemberActive(congregationId);
    }
    
    match /congregations/{congregationId}/territories/{territoryId}/{collection}/{docId} {
      allow read, create, delete, update: if isMemberActive(congregationId);
    }
  }
}