
rules_version = '2';

service cloud.firestore {
    match /databases/{database}/documents {

        function isAuth() { return request.auth != null; }
        function getUserData(userId) { return get(/databases/$(database)/documents/users/$(userId)).data; }
        function isUserInCongregation(congId) { let userData = getUserData(request.auth.uid); return userData != null && userData.congregationId == congId; }
        function isRole(role) { let userData = getUserData(request.auth.uid); return userData != null && userData.role == role; }
        function isAdmin() { return isRole('Administrador'); }
        function isDirigente() { return isRole('Dirigente'); }
        function isServoTerritorios() { return isRole('Servo de Territórios'); }
        function canApproveUsers() { return isServoTerritorios() || isDirigente() || isAdmin(); }

        match /congregations/{congId} {
            // Qualquer um logado pode pesquisar uma congregação pelo número para se cadastrar
            allow read: if isAuth(); 
            // Somente o criador inicial (Admin) pode criar uma nova
            allow create: if isAuth();
            allow update, delete: if isUserInCongregation(congId) && isAdmin();

            match /territories/{terrId} {
                allow read: if isUserInCongregation(congId);
                allow create, delete: if isUserInCongregation(congId) && (isAdmin() || isServoTerritorios());
                allow update: if isUserInCongregation(congId);

                match /quadras/{quadraId} {
                    allow read, write: if isUserInCongregation(congId);
                    match /casas/{casaId} { allow read, write: if isUserInCongregation(congId); }
                }
                match /activityHistory/{activityId} { allow read, write: if isUserInCongregation(congId); }
            }
        }

        match /users/{userId} {
            allow create: if isAuth() && request.auth.uid == userId;
            allow get: if isAuth();
            allow list: if isAuth();
            allow update: if isAuth() && (request.auth.uid == userId || canApproveUsers());
            allow delete: if false; // Não permitimos exclusão física no Spark, apenas bloqueio via status
        }

        match /feedbacks/{feedbackId} { allow create: if isAuth(); }
    }
}
