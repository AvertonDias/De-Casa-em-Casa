rules_version = '2';

service cloud.firestore {
    match /databases/{database}/documents {

        // --- FUNÇÕES AUXILIARES ---
        
        function isAuth() { return request.auth != null; }
        
        function getProfile() {
            return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
        }
        
        function isAtivo(profile) {
            return profile != null && profile.status == 'ativo';
        }
        
        function isUserInCongregation(profile, congId) { 
            return profile != null && profile.congregationId == congId; 
        }
        
        function hasRole(profile, role) { 
            return profile != null && profile.role == role; 
        }

        // --- REGRAS POR COLEÇÃO ---

        match /congregations/{congId} {
            allow read: if true; 
            allow create: if isAuth();
            
            allow update: if isAuth() && 
                (let profile = getProfile(); 
                 isUserInCongregation(profile, congId) && 
                 (isAtivo(profile) || profile.role in ['Administrador', 'Dirigente', 'Servo de Territórios', 'Ajudante de Servo de Territórios']));
            
            allow delete: if isAuth() && 
                (let profile = getProfile(); 
                 isUserInCongregation(profile, congId) && profile.role == 'Administrador');

            match /territories/{terrId} {
                allow read: if isAuth() && 
                    (let profile = getProfile(); 
                     isUserInCongregation(profile, congId) && (isAtivo(profile) || profile.role in ['Administrador', 'Dirigente', 'Servo de Territórios', 'Ajudante de Servo de Territórios']));
                
                allow create, delete: if isAuth() && 
                    (let profile = getProfile(); 
                     isUserInCongregation(profile, congId) && profile.role in ['Administrador', 'Servo de Territórios']);
                
                allow update: if isAuth() && 
                    (let profile = getProfile(); 
                     isUserInCongregation(profile, congId) && (isAtivo(profile) || profile.role in ['Administrador', 'Dirigente', 'Servo de Territórios', 'Ajudante de Servo de Territórios']));

                match /quadras/{quadraId} {
                    allow read, write: if isAuth() && 
                        (let profile = getProfile(); 
                         isUserInCongregation(profile, congId) && (isAtivo(profile) || profile.role in ['Administrador', 'Dirigente', 'Servo de Territórios', 'Ajudante de Servo de Territórios']));
                    
                    match /casas/{casaId} { 
                        allow read, write: if isAuth() && 
                            (let profile = getProfile(); 
                             isUserInCongregation(profile, congId) && (isAtivo(profile) || profile.role in ['Administrador', 'Dirigente', 'Servo de Territórios', 'Ajudante de Servo de Territórios']));
                    }
                }
                match /activityHistory/{activityId} { 
                    allow read, write: if isAuth() && 
                        (let profile = getProfile(); 
                         isUserInCongregation(profile, congId) && (isAtivo(profile) || profile.role in ['Administrador', 'Dirigente', 'Servo de Territórios', 'Ajudante de Servo de Territórios']));
                }
            }
            
            match /auditLogs/{logId} {
                allow read: if isAuth() && 
                    (let profile = getProfile(); 
                     isUserInCongregation(profile, congId) && profile.role == 'Administrador');
                
                allow create: if isAuth() && 
                    (let profile = getProfile(); 
                     isUserInCongregation(profile, congId) && isAtivo(profile));
            }
        }

        match /users/{userId} {
            allow create: if isAuth() && request.auth.uid == userId;
            allow get: if isAuth();
            allow list: if isAuth();
            
            allow update: if isAuth() && 
                (request.auth.uid == userId || 
                 (let profile = getProfile(); 
                  profile.role in ['Administrador', 'Dirigente', 'Servo de Territórios', 'Ajudante de Servo de Territórios']));
            
            allow delete: if isAuth() && 
                (request.auth.uid == userId || 
                 (let profile = getProfile(); profile.role == 'Administrador'));

            match /notifications/{notifId} {
                allow get, list, update, delete: if isAuth() && request.auth.uid == userId;
                allow create: if isAuth() && 
                    (request.auth.uid == userId || 
                     (let profile = getProfile(); 
                      profile.role in ['Administrador', 'Dirigente', 'Servo de Territórios', 'Ajudante de Servo de Territórios']));
            }
        }

        match /resetTokens/{tokenId} {
            allow read, delete: if true;
            allow create: if true;
        }

        match /feedbacks/{feedbackId} { allow create: if isAuth(); }
    }
}